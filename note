#!/usr/bin/env bash
#
# note - notes navigation and scaffolding
#
# Standalone script; symlink into $PATH (see symlink_scripts). Owns
# cross-notebook ops only — inside a notebook, use vim + wikijump.vim
# plugin.
# No command mutates the parent shell; compose with cd $(note where).

show_help() {
    cat <<'EOF'
note - notes navigation and scaffolding

USAGE
    note <command> [args]

COMMANDS
    find            fzf any .md under $NOTE_HOME, open in vim
    where           fzf a notebook root, print its path
    new <t> <path>  scaffold notebook from $NOTE_HOME/_templates/<t>
                      at <path> (relative to current directory)
    home            print $NOTE_HOME
    completion      print bash completion script to stdout
    help            show this message

COMPOSE
    cd $(note where)            jump to a notebook
    vim $(note home)            netrw on notes root

Use z (or any directory jumper) for frequently-visited notebooks.
Inside a notebook, use vim + wikijump.

ENVIRONMENT
    NOTE_HOME       notes root (default: ~/notes)

TEMPLATES
    $NOTE_HOME/_templates/<name>/     directory templates for `note new`

INSTALL COMPLETION
    bash:   note completion > ~/.local/share/bash-completion/completions/note
    zsh:    autoload -U +X bashcompinit && bashcompinit
            note completion > "${fpath[1]}/_note"
    eval:   eval "$(note completion)"
EOF
}

main() {
    local home="${NOTE_HOME:-$HOME/notes}"

    case "$1" in
    ""|help|-h|--help)
        show_help
        ;;

    find)
        local f
        f=$(rg --files --type md --glob '!_*' "$home" | fzf) \
            && [ -n "$f" ] && vim "$f"
        ;;

    where)
        find "$home" -name .wikijump \
            -not -path '*/_*' -not -path '*/.*/*' -printf '%h\n' | fzf
        ;;

    new)
        if [ -z "$2" ] || [ -z "$3" ]; then
            echo "usage: note new <template> <path>" >&2
            exit 1
        fi
        local src="$home/_templates/$2"
        local dst="$3"
        [ -d "$src" ] || { echo "no template: $2" >&2; exit 1; }
        [ ! -e "$dst" ] || { echo "exists: $dst" >&2; exit 1; }
        cp -r "$src" "$dst" || exit 1
        # Landing page name follows wikijump: first non-blank line of
        # the marker, else README.md.
        local index
        index=$(awk 'NF{gsub(/^[ \t]+|[ \t]+$/,"");print;exit}' \
                "$dst/.wikijump" 2>/dev/null)
        vim "$dst/${index:-README.md}"
        ;;

    home)
        echo "$home"
        ;;

    completion)
        cat <<'EOF'
_note() {
    local cur="${COMP_WORDS[COMP_CWORD]}"
    local home="${NOTE_HOME:-$HOME/notes}"

    case "$COMP_CWORD" in
        1)
            COMPREPLY=($(compgen -W "find where new home help completion" -- "$cur"))
            ;;
        2)
            [ "${COMP_WORDS[1]}" = new ] \
                && COMPREPLY=($(cd "$home/_templates" 2>/dev/null && compgen -d -- "$cur"))
            ;;
        3)
            [ "${COMP_WORDS[1]}" = new ] \
                && COMPREPLY=($(compgen -d -- "$cur"))
            ;;
    esac
}
complete -F _note note
EOF
        ;;

    *)
        echo "unknown command: $1" >&2
        show_help
        exit 1
        ;;
    esac
}

main "$@"
