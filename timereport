#!/usr/bin/env python3
"""
timereport - Zeit time tracking visualizer

Generates various time reports from zeit export data.
Reads JSON from stdin (zeit export -f json | timereport).
Requires Python 3.10+.

Usage:
    zeit export -f json | timereport [dimensions...] [--period EXPR]

Examples:
    zeit export -f json | timereport project
    zeit export -f json | timereport dailycal --period week
"""

# ============================================================================
# SECTION 1: IMPORTS & CONSTANTS
# ============================================================================

import sys
import json
import re
import argparse
from datetime import datetime, timedelta
from dataclasses import dataclass, replace
from collections import defaultdict

# Constants
TEMPORAL_DIMS = {'day', 'week', 'month', 'year'}
CATEGORICAL_DIMS = {'project', 'tag'}

DAY_NAMES_SHORT = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun']
DAY_NAMES_FULL = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday']

MONTH_NAMES_SHORT = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun',
                     'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec']
MONTH_NAMES_FULL = ['January', 'February', 'March', 'April', 'May', 'June',
                    'July', 'August', 'September', 'October', 'November', 'December']

SECONDS_PER_DAY = 86400
SECONDS_PER_HOUR = 3600

# Sparse format constants
SPARSE_BOX_HEIGHT = 6
SPARSE_GAP_HEIGHT = 1

# Display constants
NO_TAG_LABEL = "(no tag)"
NO_PROJECT_LABEL = "(no project)"
ADJACENCY_TOLERANCE_SEC = 60
GRID_DAY_COL_WIDTH = 19
COMPACT_FORMAT_WIDTH = 69
CROSSTAB_TRANSPOSE_THRESHOLD = 6
CROSSTAB_COL_WIDTH = 8


# ============================================================================
# SECTION 2: DATA MODELS
# ============================================================================

@dataclass
class Segment:
    """Single time tracking segment (after midnight splitting)"""
    project: str | None
    tags: list[str]
    description: str
    start_epoch: int
    end_epoch: int
    duration_sec: int
    day: str          # "Mon", "Tue", ...
    day_num: int      # 0-6 (Mon=0)
    week: int         # ISO week 1-52
    month: str        # "Jan", "Feb", ...
    month_num: int    # 1-12
    year: int


@dataclass
class DimensionSpec:
    """Specification of a reporting dimension"""
    name: str
    is_temporal: bool
    is_categorical: bool


@dataclass
class CommandSpec:
    """Parsed command specification"""
    command_type: str  # "dimension_report", "dailycal", "default_1d"
    dimensions: list[DimensionSpec]
    period_expr: str | None
    flags: dict[str, bool]  # compact, sparse


@dataclass
class AggregatedData:
    """Aggregated segments by dimensions"""
    data: dict
    dimensions: list[str]
    total_duration: int
    period_range: tuple[int, int] | None  # (begin_epoch, end_epoch)
    segments: list[Segment]  # Keep original segments for daily calendar


@dataclass
class BoxPlacement:
    """Placement of a segment box in the daily calendar grid"""
    segment: Segment
    day_idx: int       # Day of week (0-6, Mon-Sun)
    start_row: int     # Grid row where box starts
    end_row: int       # Grid row where box ends (exclusive)
    column: int        # Sub-column within day (0-2 for overlaps)


# ============================================================================
# SECTION 3: COMMAND ROUTING & VALIDATION
# ============================================================================

def detect_command_type(args: list[str]) -> tuple[str, list[str]]:
    """
    Detect command type from first positional argument.
    Returns: (command_type, remaining_args)
    """
    if not args:
        return ("default_1d", [])

    match args[0]:
        case "dailycal":
            return ("dailycal", args[1:])
        case _:
            # Regular dimension report
            return ("dimension_report", args)


def parse_dimensions(args: list[str]) -> list[DimensionSpec]:
    """Parse dimension arguments and validate combinations"""
    if not args:
        raise ValueError("At least one dimension required")

    dims = []
    for arg in args:
        match arg:
            case "project" | "tag":
                dims.append(DimensionSpec(arg, False, True))
            case "day" | "week" | "month" | "year":
                dims.append(DimensionSpec(arg, True, False))
            case _:
                raise ValueError(f"Invalid dimension: {arg}")

    # Validate dimension combinations
    validate_dimension_combo(dims)
    return dims


def validate_dimension_combo(dims: list[DimensionSpec]) -> None:
    """Validate dimension combinations"""
    if len(dims) > 2:
        raise ValueError("Maximum 2 dimensions supported")
    if len(dims) == 2:
        has_cat = any(d.is_categorical for d in dims)
        has_temp = any(d.is_temporal for d in dims)
        if not (has_cat and has_temp):
            raise ValueError(
                "2D reports require one categorical (project, tag) "
                "and one temporal (day, week, month, year) dimension"
            )


def build_command_spec(args: argparse.Namespace) -> CommandSpec:
    """Build complete command specification from parsed CLI args"""
    # Detect command type
    cmd_type, dim_args = detect_command_type(args.dimensions)

    # Handle command aliases and special cases
    match cmd_type:
        case "dailycal":
            dimensions = []  # Special handling - no dimension aggregation
            # Allow inline period: `dailycal week` == `dailycal --period week`
            if dim_args:
                if args.period:
                    raise ValueError("Cannot specify both inline period and --period")
                args.period = dim_args[0]
        case "dimension_report":
            dimensions = parse_dimensions(dim_args)
        case "default_1d":
            dimensions = parse_dimensions(["project"])

    return CommandSpec(
        command_type=cmd_type,
        dimensions=dimensions,
        period_expr=args.period,
        flags={
            "compact": getattr(args, 'compact', False),
            "sparse": getattr(args, 'sparse', False),
        }
    )


# ============================================================================
# SECTION 4: DATA PIPELINE
# ============================================================================

# Stage 4.1: Data Loading
# ------------------------

def load_zeit_data() -> dict:
    """Load zeit export JSON from stdin."""
    if sys.stdin.isatty():
        raise RuntimeError(
            "No data on stdin. Usage: zeit export -f json | timereport ..."
        )

    json_data = sys.stdin.read()
    if not json_data or json_data.strip() == "":
        raise RuntimeError("No data received from stdin")

    try:
        return json.loads(json_data)
    except json.JSONDecodeError as e:
        raise RuntimeError(f"Failed to parse JSON: {e}")


# Stage 4.2: Segment Extraction & Validation
# -------------------------------------------

def parse_rfc3339(timestamp: str) -> int:
    """Parse RFC3339 timestamp to epoch seconds."""
    # Handle Z suffix and timezone offsets
    ts = timestamp.replace("Z", "+00:00")
    dt = datetime.fromisoformat(ts)
    return int(dt.timestamp())


def extract_segments(blocks: dict) -> list[tuple[dict, int, int]]:
    """
    Extract raw segments from zeit export blocks.
    Returns: list of (task_context, start_epoch, end_epoch)
    """
    segments = []
    for block in blocks.values():
        # Skip non-block entries (config, activeblock, etc.)
        if not isinstance(block, dict):
            continue
        if "start" not in block or "end" not in block:
            continue

        try:
            start = parse_rfc3339(block["start"])
            end = parse_rfc3339(block["end"])
        except (ValueError, TypeError):
            continue

        if not validate_segment(start, end):
            continue

        # Map zeit fields: project_sid -> project, task_sid -> description
        project = block.get("project_sid", "")
        task_sid = block.get("task_sid", "")
        note = block.get("note", "")
        # Use task_sid as description, append note if present
        description = task_sid
        if note:
            description = f"{task_sid}: {note}" if task_sid else note

        context = {
            "project": project or None,
            "tags": [],
            "description": description,
        }
        segments.append((context, start, end))

    return segments


def validate_segment(start: int, end: int) -> bool:
    """Validate segment times"""
    if start is None or end is None:
        return False
    if start >= end:  # No negative or zero durations
        return False
    if start < 0 or end < 0:  # No time travel
        return False
    return True


# Stage 4.3: Midnight Splitting & Temporal Extraction
# ---------------------------------------------------

def preprocess_segments(raw_segments: list[tuple[dict, int, int]]) -> list[Segment]:
    """Split at midnight and extract temporal dimensions"""
    processed = []

    for context, start, end in raw_segments:
        # Split at midnight boundaries
        split_ranges = midnight_split(start, end)

        for seg_start, seg_end in split_ranges:
            # Extract temporal dimensions from start time
            temporal = extract_temporal_dims(seg_start)

            processed.append(Segment(
                project=context["project"],
                tags=context["tags"],
                description=context["description"],
                start_epoch=seg_start,
                end_epoch=seg_end,
                duration_sec=seg_end - seg_start,
                **temporal
            ))

    return processed


def midnight_split(start: int, end: int) -> list[tuple[int, int]]:
    """Split segment at midnight (00:00:00) boundaries"""
    segments = []
    current = start

    while current < end:
        # Convert current epoch to local datetime
        current_dt = datetime.fromtimestamp(current)

        # Find the end of the current day (23:59:59) in local timezone
        current_day_end_dt = current_dt.replace(
            hour=23, minute=59, second=59, microsecond=0
        )
        current_day_end = int(current_day_end_dt.timestamp())

        if end <= current_day_end:
            # Segment ends before midnight
            segments.append((current, end))
            break
        else:
            # Segment crosses midnight
            segments.append((current, current_day_end))
            current = current_day_end + 1  # 00:00:00 next day

    return segments


def extract_temporal_dims(epoch: int) -> dict:
    """Extract all temporal dimensions from epoch time"""
    dt = datetime.fromtimestamp(epoch)
    iso = dt.isocalendar()

    return {
        "day": DAY_NAMES_SHORT[dt.weekday()],
        "day_num": dt.weekday(),
        "week": iso.week,
        "month": MONTH_NAMES_SHORT[dt.month - 1],
        "month_num": dt.month,
        "year": dt.year
    }


# Stage 4.4: Tag Expansion
# ------------------------

def expand_tags(segments: list[Segment]) -> list[Segment]:
    """
    Expand segments with multiple tags into separate segments.
    Called only when 'tag' dimension is requested.
    """
    expanded = []
    for seg in segments:
        if seg.tags:
            for tag in seg.tags:
                # Create copy with single tag
                expanded.append(replace(seg, tags=[tag]))
        else:
            # No tags -> keep as placeholder
            expanded.append(replace(seg, tags=[NO_TAG_LABEL]))

    return expanded


# Stage 4.5: Period Filtering
# ---------------------------

def apply_period_filter(segments: list[Segment], period_expr: str) -> list[Segment]:
    """Filter segments by period expression"""
    if not period_expr:
        return segments

    begin, end = parse_period_expression(period_expr)

    return [
        seg for seg in segments
        if seg.start_epoch < end and seg.end_epoch > begin
    ]


def parse_period_expression(expr: str) -> tuple[int, int]:
    """
    Parse period expression to (begin_epoch, end_epoch).
    Uses only datetime stdlib (no dateutil).
    """
    now = datetime.now()
    today_start = now.replace(hour=0, minute=0, second=0, microsecond=0)

    match expr:
        case "today":
            begin = today_start
            end = today_start + timedelta(days=1) - timedelta(seconds=1)

        case "yesterday":
            begin = today_start - timedelta(days=1)
            end = today_start - timedelta(seconds=1)

        case "week":
            # Current week (Monday to Sunday)
            week_start = today_start - timedelta(days=now.weekday())
            begin = week_start
            end = week_start + timedelta(days=7) - timedelta(seconds=1)

        case "lastweek":
            week_start = today_start - timedelta(days=now.weekday() + 7)
            begin = week_start
            end = week_start + timedelta(days=7) - timedelta(seconds=1)

        case "month":
            month_start = today_start.replace(day=1)
            begin = month_start
            # Last day of month
            next_month = (month_start + timedelta(days=32)).replace(day=1)
            end = next_month - timedelta(seconds=1)

        case "lastmonth":
            month_start = today_start.replace(day=1)
            last_month_start = (month_start - timedelta(days=1)).replace(day=1)
            begin = last_month_start
            end = month_start - timedelta(seconds=1)

        case "year":
            year_start = today_start.replace(month=1, day=1)
            begin = year_start
            end = year_start.replace(year=year_start.year + 1) - timedelta(seconds=1)

        case "lastyear":
            year_start = today_start.replace(month=1, day=1, year=now.year - 1)
            begin = year_start
            end = year_start.replace(year=year_start.year + 1) - timedelta(seconds=1)

        case _:
            # Try multi-period pattern (Ndays, Nweeks, etc.)
            begin, end = parse_multi_period(expr, today_start)

    return (int(begin.timestamp()), int(end.timestamp()))


def parse_multi_period(expr: str, today_start: datetime) -> tuple[datetime, datetime]:
    """Parse multi-period expressions like '3weeks', '2months'"""
    match = re.match(r'^(\d+)(days?|weeks?|months?|years?)$', expr.lower())
    if not match:
        raise ValueError(f"Invalid period expression: {expr}")

    count = int(match.group(1))
    unit = match.group(2).rstrip('s')  # Remove trailing 's' if present

    if count < 2:
        raise ValueError(f"Multi-period count must be >= 2: {expr}")

    end = today_start + timedelta(days=1) - timedelta(seconds=1)

    match unit:
        case "day":
            begin = today_start - timedelta(days=count - 1)
        case "week":
            # Go back to Monday of current week, then back (count-1) more weeks
            current_week_start = today_start - timedelta(days=today_start.weekday())
            begin = current_week_start - timedelta(weeks=count - 1)
        case "month":
            # Current month + (count-1) previous months
            begin = today_start.replace(day=1)
            for _ in range(count - 1):
                begin = (begin - timedelta(days=1)).replace(day=1)
        case "year":
            begin = today_start.replace(month=1, day=1, year=today_start.year - count + 1)
        case _:
            raise ValueError(f"Invalid period unit: {unit}")

    return (begin, end)


# Stage 4.6: Aggregation
# ----------------------

def get_dimension_value(seg: Segment, dim: str) -> str:
    """Get dimension value from segment"""
    match dim:
        case "project":
            if seg.project:
                return seg.project
            return NO_PROJECT_LABEL
        case "tag":
            if seg.tags and seg.tags[0] != NO_TAG_LABEL:
                return seg.tags[0]
            return NO_TAG_LABEL
        case "day":
            return seg.day
        case "week":
            return f"W{seg.week}"
        case "month":
            return seg.month
        case "year":
            return str(seg.year)
        case _:
            raise ValueError(f"Unknown dimension: {dim}")


def aggregate_by_dimensions(
    segments: list[Segment],
    dimensions: list[str],
) -> AggregatedData:
    """Aggregate segments by specified dimensions"""
    if not dimensions:
        # No dimensions - just return total
        total = sum(seg.duration_sec for seg in segments)
        period = None
        if segments:
            period = (
                min(s.start_epoch for s in segments),
                max(s.end_epoch for s in segments)
            )
        return AggregatedData(
            data={},
            dimensions=[],
            total_duration=total,
            period_range=period,
            segments=segments
        )

    # Build nested dictionary keyed by dimensions
    data = {}

    for seg in segments:
        # Build composite key from dimension values
        keys = [get_dimension_value(seg, dim) for dim in dimensions]

        # Navigate/create nested dict structure
        current = data
        for i, key in enumerate(keys[:-1]):
            if key not in current:
                current[key] = {}
            current = current[key]

        # Add/update leaf value
        last_key = keys[-1]
        if last_key not in current:
            current[last_key] = 0
        current[last_key] += seg.duration_sec

    # Calculate total and period range
    total = sum(seg.duration_sec for seg in segments)
    period = None
    if segments:
        period = (
            min(s.start_epoch for s in segments),
            max(s.end_epoch for s in segments)
        )

    return AggregatedData(
        data=data,
        dimensions=dimensions,
        total_duration=total,
        period_range=period,
        segments=segments
    )


