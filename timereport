#!/usr/bin/env python3
"""
timereport - Zeit time tracking visualizer

Generates various time reports from zeit export data.
Reads JSON from stdin (zeit export -f json | timereport).
Requires Python 3.10+.

Usage:
    zeit export -f json | timereport [dimensions...] [--period EXPR]

Examples:
    zeit export -f json | timereport project
    zeit export -f json | timereport task --period month
    zeit export -f json | timereport dailycal --period week
"""

# ============================================================================
# SECTION 1: IMPORTS & CONSTANTS
# ============================================================================

import sys
import json
import re
import argparse
from datetime import datetime, timedelta
from dataclasses import dataclass
from collections import defaultdict

# Constants
TEMPORAL_DIMS = {'day', 'week', 'month', 'year'}
CATEGORICAL_DIMS = {'project', 'task'}

DAY_NAMES_SHORT = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun']
DAY_NAMES_FULL = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday']

MONTH_NAMES_SHORT = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun',
                     'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec']

SECONDS_PER_HOUR = 3600

# Sparse format constants
SPARSE_BOX_HEIGHT = 6
SPARSE_GAP_HEIGHT = 1

# Display constants
NO_TASK_LABEL = "(no task)"
NO_PROJECT_LABEL = "(no project)"
ADJACENCY_TOLERANCE_SEC = 60
GRID_DAY_COL_WIDTH = 19
COMPACT_FORMAT_WIDTH = 69
CROSSTAB_TRANSPOSE_THRESHOLD = 6
CROSSTAB_COL_WIDTH = 8


# ============================================================================
# SECTION 2: DATA MODELS
# ============================================================================

@dataclass
class Segment:
    """Single time tracking segment (after midnight splitting)"""
    project: str | None
    task: str | None
    description: str
    start_epoch: int
    end_epoch: int
    duration_sec: int
    day: str          # "Mon", "Tue", ...
    day_num: int      # 0-6 (Mon=0)
    week: int         # ISO week 1-52
    month: str        # "Jan", "Feb", ...
    month_num: int    # 1-12
    year: int


@dataclass
class DimensionSpec:
    """Specification of a reporting dimension"""
    name: str

    @property
    def is_temporal(self) -> bool:
        return self.name in TEMPORAL_DIMS

    @property
    def is_categorical(self) -> bool:
        return self.name in CATEGORICAL_DIMS


@dataclass
class CommandSpec:
    """Parsed command specification"""
    command_type: str  # "dimension_report", "dailycal", "default_1d"
    dimensions: list[DimensionSpec]
    period_expr: str | None
    compact: bool
    sparse: bool


@dataclass
class AggregatedData:
    """Aggregated segments by dimensions"""
    data: dict
    dimensions: list[str]
    total_duration: int
    period_range: tuple[int, int] | None  # (begin_epoch, end_epoch)
    segments: list[Segment]  # Keep original segments for daily calendar


@dataclass
class BoxPlacement:
    """Placement of a segment box in the daily calendar grid"""
    segment: Segment
    day_idx: int       # Day of week (0-6, Mon-Sun)
    start_row: int     # Grid row where box starts
    end_row: int       # Grid row where box ends (exclusive)
    column: int        # Sub-column within day (0-2 for overlaps)


# ============================================================================
# SECTION 3: COMMAND ROUTING & VALIDATION
# ============================================================================

def detect_command_type(args: list[str]) -> tuple[str, list[str]]:
    """
    Detect command type from first positional argument.
    Returns: (command_type, remaining_args)
    """
    if not args:
        return ("default_1d", [])

    match args[0]:
        case "dailycal":
            return ("dailycal", args[1:])
        case _:
            # Regular dimension report
            return ("dimension_report", args)


def parse_dimensions(args: list[str]) -> list[DimensionSpec]:
    """Parse dimension arguments and validate combinations"""
    if not args:
        raise ValueError("At least one dimension required")

    for arg in args:
        if arg not in TEMPORAL_DIMS and arg not in CATEGORICAL_DIMS:
            raise ValueError(f"Invalid dimension: {arg}")

    dims = [DimensionSpec(arg) for arg in args]
    validate_dimension_combo(dims)
    return dims


def validate_dimension_combo(dims: list[DimensionSpec]) -> None:
    """Validate dimension combinations"""
    if len(dims) > 2:
        raise ValueError("Maximum 2 dimensions supported")
    if len(dims) == 2:
        has_cat = any(d.is_categorical for d in dims)
        has_temp = any(d.is_temporal for d in dims)
        if not (has_cat and has_temp):
            raise ValueError(
                "2D reports require one categorical (project, task) "
                "and one temporal (day, week, month, year) dimension"
            )


def build_command_spec(args: argparse.Namespace) -> CommandSpec:
    """Build complete command specification from parsed CLI args"""
    # Detect command type
    cmd_type, dim_args = detect_command_type(args.dimensions)

    # Handle command aliases and special cases
    match cmd_type:
        case "dailycal":
            dimensions = []  # Special handling - no dimension aggregation
            # Allow inline period: `dailycal week` == `dailycal --period week`
            if dim_args:
                if args.period:
                    raise ValueError("Cannot specify both inline period and --period")
                args.period = dim_args[0]
        case "dimension_report":
            dimensions = parse_dimensions(dim_args)
        case "default_1d":
            dimensions = parse_dimensions(["project"])

    return CommandSpec(
        command_type=cmd_type,
        dimensions=dimensions,
        period_expr=args.period,
        compact=args.compact,
        sparse=args.sparse,
    )


# ============================================================================
# SECTION 4: DATA PIPELINE
# ============================================================================

# Stage 4.1: Data Loading
# ------------------------

def load_zeit_data() -> dict:
    """Load zeit export JSON from stdin."""
    if sys.stdin.isatty():
        raise RuntimeError(
            "No data on stdin. Usage: zeit export -f json | timereport ..."
        )

    json_data = sys.stdin.read()
    if not json_data.strip():
        raise RuntimeError("No data received from stdin")

    try:
        return json.loads(json_data)
    except json.JSONDecodeError as e:
        raise RuntimeError(f"Failed to parse JSON: {e}")


# Stage 4.2: Segment Extraction & Validation
# -------------------------------------------

def parse_rfc3339(timestamp: str) -> int:
    """Parse RFC3339 timestamp to epoch seconds."""
    # Handle Z suffix and timezone offsets
    ts = timestamp.replace("Z", "+00:00")
    dt = datetime.fromisoformat(ts)
    return int(dt.timestamp())


def extract_segments(blocks: dict) -> list[tuple[dict, int, int]]:
    """
    Extract raw segments from zeit export blocks.
    Returns: list of (task_context, start_epoch, end_epoch)
    """
    segments = []
    for block in blocks.values():
        # Skip non-block entries (config, activeblock, etc.)
        if not isinstance(block, dict):
            continue
        if "start" not in block or "end" not in block:
            continue

        try:
            start = parse_rfc3339(block["start"])
            end = parse_rfc3339(block["end"])
        except (ValueError, TypeError):
            continue

        if not validate_segment(start, end):
            continue

        # Map zeit fields: project_sid -> project, task_sid -> task, note -> description
        project = block.get("project_sid", "")
        task_sid = block.get("task_sid", "")
        note = block.get("note", "")

        context = {
            "project": project or None,
            "task": task_sid or None,
            "description": note,
        }
        segments.append((context, start, end))

    return segments


def validate_segment(start: int, end: int) -> bool:
    """Validate segment times"""
    if start is None or end is None:
        return False
    if start >= end:  # No negative or zero durations
        return False
    if start < 0 or end < 0:  # No time travel
        return False
    return True


# Stage 4.3: Midnight Splitting & Temporal Extraction
# ---------------------------------------------------

def preprocess_segments(raw_segments: list[tuple[dict, int, int]]) -> list[Segment]:
    """Split at midnight and extract temporal dimensions"""
    processed = []

    for context, start, end in raw_segments:
        # Split at midnight boundaries
        split_ranges = midnight_split(start, end)

        for seg_start, seg_end in split_ranges:
            # Extract temporal dimensions from start time
            temporal = extract_temporal_dims(seg_start)

            processed.append(Segment(
                project=context["project"],
                task=context["task"],
                description=context["description"],
                start_epoch=seg_start,
                end_epoch=seg_end,
                duration_sec=seg_end - seg_start,
                **temporal
            ))

    return processed


def midnight_split(start: int, end: int) -> list[tuple[int, int]]:
    """Split segment at midnight (00:00:00) boundaries"""
    segments = []
    current = start

    while current < end:
        # Convert current epoch to local datetime
        current_dt = datetime.fromtimestamp(current)

        # Find the end of the current day (23:59:59) in local timezone
        current_day_end_dt = current_dt.replace(
            hour=23, minute=59, second=59, microsecond=0
        )
        current_day_end = int(current_day_end_dt.timestamp())

        if end <= current_day_end:
            # Segment ends before midnight
            segments.append((current, end))
            break
        else:
            # Segment crosses midnight
            segments.append((current, current_day_end))
            current = current_day_end + 1  # 00:00:00 next day

    return segments


def extract_temporal_dims(epoch: int) -> dict:
    """Extract all temporal dimensions from epoch time"""
    dt = datetime.fromtimestamp(epoch)
    iso = dt.isocalendar()

    return {
        "day": DAY_NAMES_SHORT[dt.weekday()],
        "day_num": dt.weekday(),
        "week": iso.week,
        "month": MONTH_NAMES_SHORT[dt.month - 1],
        "month_num": dt.month,
        "year": dt.year
    }


# Stage 4.4: Period Filtering
# ---------------------------

def apply_period_filter(segments: list[Segment], period_expr: str) -> list[Segment]:
    """Filter segments by period expression"""
    if not period_expr:
        return segments

    begin, end = parse_period_expression(period_expr)

    return [
        seg for seg in segments
        if seg.start_epoch < end and seg.end_epoch > begin
    ]


def parse_period_expression(expr: str) -> tuple[int, int]:
    """
    Parse period expression to (begin_epoch, end_epoch).
    Uses only datetime stdlib (no dateutil).
    """
    now = datetime.now()
    today_start = now.replace(hour=0, minute=0, second=0, microsecond=0)

    match expr:
        case "today":
            begin = today_start
            end = today_start + timedelta(days=1) - timedelta(seconds=1)

        case "yesterday":
            begin = today_start - timedelta(days=1)
            end = today_start - timedelta(seconds=1)

        case "week":
            # Current week (Monday to Sunday)
            week_start = today_start - timedelta(days=now.weekday())
            begin = week_start
            end = week_start + timedelta(days=7) - timedelta(seconds=1)

        case "lastweek":
            week_start = today_start - timedelta(days=now.weekday() + 7)
            begin = week_start
            end = week_start + timedelta(days=7) - timedelta(seconds=1)

        case "month":
            month_start = today_start.replace(day=1)
            begin = month_start
            # Last day of month
            next_month = (month_start + timedelta(days=32)).replace(day=1)
            end = next_month - timedelta(seconds=1)

        case "lastmonth":
            month_start = today_start.replace(day=1)
            last_month_start = (month_start - timedelta(days=1)).replace(day=1)
            begin = last_month_start
            end = month_start - timedelta(seconds=1)

        case "year":
            year_start = today_start.replace(month=1, day=1)
            begin = year_start
            end = year_start.replace(year=year_start.year + 1) - timedelta(seconds=1)

        case "lastyear":
            year_start = today_start.replace(month=1, day=1, year=now.year - 1)
            begin = year_start
            end = year_start.replace(year=year_start.year + 1) - timedelta(seconds=1)

        case _:
            # Try multi-period pattern (Ndays, Nweeks, etc.)
            begin, end = parse_multi_period(expr, today_start)

    return (int(begin.timestamp()), int(end.timestamp()))


def parse_multi_period(expr: str, today_start: datetime) -> tuple[datetime, datetime]:
    """Parse multi-period expressions like '3weeks', '2months'"""
    match = re.match(r'^(\d+)(days?|weeks?|months?|years?)$', expr.lower())
    if not match:
        raise ValueError(f"Invalid period expression: {expr}")

    count = int(match.group(1))
    unit = match.group(2).rstrip('s')  # Remove trailing 's' if present

    if count < 2:
        raise ValueError(f"Multi-period count must be >= 2: {expr}")

    end = today_start + timedelta(days=1) - timedelta(seconds=1)

    match unit:
        case "day":
            begin = today_start - timedelta(days=count - 1)
        case "week":
            # Go back to Monday of current week, then back (count-1) more weeks
            current_week_start = today_start - timedelta(days=today_start.weekday())
            begin = current_week_start - timedelta(weeks=count - 1)
        case "month":
            # Current month + (count-1) previous months
            begin = today_start.replace(day=1)
            for _ in range(count - 1):
                begin = (begin - timedelta(days=1)).replace(day=1)
        case "year":
            begin = today_start.replace(month=1, day=1, year=today_start.year - count + 1)
        case _:
            raise ValueError(f"Invalid period unit: {unit}")

    return (begin, end)


# Stage 4.5: Aggregation
# ----------------------

def get_dimension_value(seg: Segment, dim: str) -> str:
    """Get dimension value from segment"""
    match dim:
        case "project":
            if seg.project:
                return seg.project
            return NO_PROJECT_LABEL
        case "task":
            # Tasks are scoped to their project (zeit nests task_sid in project_sid)
            project = seg.project or NO_PROJECT_LABEL
            task = seg.task or NO_TASK_LABEL
            return f"{project}/{task}"
        case "day":
            return seg.day
        case "week":
            return f"W{seg.week}"
        case "month":
            return seg.month
        case "year":
            return str(seg.year)
        case _:
            raise ValueError(f"Unknown dimension: {dim}")


def aggregate_by_dimensions(
    segments: list[Segment],
    dimensions: list[str],
) -> AggregatedData:
    """Aggregate segments by specified dimensions"""
    total = sum(seg.duration_sec for seg in segments)
    period = None
    if segments:
        period = (
            min(s.start_epoch for s in segments),
            max(s.end_epoch for s in segments)
        )

    # Build nested dictionary keyed by dimension values
    data = {}
    if dimensions:
        for seg in segments:
            keys = [get_dimension_value(seg, dim) for dim in dimensions]
            current = data
            for key in keys[:-1]:
                current = current.setdefault(key, {})
            current[keys[-1]] = current.get(keys[-1], 0) + seg.duration_sec

    return AggregatedData(
        data=data,
        dimensions=dimensions,
        total_duration=total,
        period_range=period,
        segments=segments
    )


# ============================================================================
# SECTION 5: FORMATTING HELPERS
# ============================================================================

def format_duration(seconds: int) -> str:
    """Format duration as X.Xh"""
    return f"{seconds / SECONDS_PER_HOUR:.1f}h"


def format_duration_compact(seconds: int) -> str:
    """Format duration in hours without 'h' suffix"""
    return f"{seconds / SECONDS_PER_HOUR:.1f}"


def format_percentage(value: float, total: float) -> str:
    """Format value as percentage of total"""
    if total == 0:
        return "(0.0%)"
    return f"({value / total * 100:.1f}%)"


def format_day(day_num: int, full: bool = False) -> str:
    """Format day name"""
    return DAY_NAMES_FULL[day_num] if full else DAY_NAMES_SHORT[day_num]


def format_period_range(begin: int, end: int) -> str:
    """Format period range for headers (e.g., 'Dec 15 (2024) - Jan 4 (2025)')"""
    begin_dt = datetime.fromtimestamp(begin)
    end_dt = datetime.fromtimestamp(end)

    begin_str = f"{MONTH_NAMES_SHORT[begin_dt.month - 1]} {begin_dt.day:02d} ({begin_dt.year})"
    end_str = f"{MONTH_NAMES_SHORT[end_dt.month - 1]} {end_dt.day:02d} ({end_dt.year})"

    return f"{begin_str} - {end_str}"


def draw_separator(width: int) -> str:
    """Draw horizontal separator (single line)"""
    return "─" * width


def draw_header_separator(width: int) -> str:
    """Draw header separator (double line)"""
    return "═" * width


def segments_adjacent(first: Segment, second: Segment) -> bool:
    """True when second starts within ADJACENCY_TOLERANCE_SEC of first's end"""
    return abs(first.end_epoch - second.start_epoch) <= ADJACENCY_TOLERANCE_SEC


# ============================================================================
# SECTION 6: MAIN RENDERER
# ============================================================================

class Renderer:
    """Render aggregated data into report formats"""

    def render(self, data: AggregatedData, spec: CommandSpec) -> str:
        """Route to appropriate rendering method"""
        match (len(data.dimensions), spec.command_type):
            case (_, "dailycal"):
                return self._render_daily_calendar(data, spec)
            case (0, _):
                return self._render_total_only(data)
            case (1, _):
                return self._render_1d(data)
            case (2, _):
                return self._render_2d(data)
            case _:
                raise ValueError(f"Unsupported dimension combination: {data.dimensions}")

    def _render_total_only(self, data: AggregatedData) -> str:
        """Render when no dimensions specified"""
        duration = format_duration(data.total_duration)
        return f"Total: {duration}\n"

    @staticmethod
    def _list_report_header(title: str, data: AggregatedData) -> tuple[str, list[str]]:
        """Header block shared by 1D list reports. Returns (full title, lines)."""
        if data.period_range:
            title += f": {format_period_range(*data.period_range)}"
        return title, [
            title,
            draw_header_separator(len(title)),
            "",
            draw_separator(len(title)),
        ]

    @staticmethod
    def _list_report_footer(width: int, label_width: int, total_duration: int) -> list[str]:
        """Total row and closing separators shared by 1D list reports."""
        total_dur = format_duration_compact(total_duration)
        return [
            draw_separator(width),
            f"{'Total':<{label_width}} {total_dur:>8}  (100.0%)",
            "",
            draw_header_separator(width),
            "",
        ]

    def _render_1d(self, data: AggregatedData) -> str:
        """Render 1D list format"""
        dim = data.dimensions[0]

        if dim == "task":
            return self._render_1d_task_nested(data)

        header, lines = self._list_report_header(dim.upper(), data)

        # Data rows
        for key, value in sorted(data.data.items()):
            duration = format_duration_compact(value)
            pct = format_percentage(value, data.total_duration)
            lines.append(f"{key:<20} {duration:>8}  {pct}")

        lines.extend(self._list_report_footer(len(header), 20, data.total_duration))
        return '\n'.join(lines)

    def _render_1d_task_nested(self, data: AggregatedData) -> str:
        """Render task report with tasks nested under their project"""
        # Build {project: {task: seconds}} from segments
        by_project = defaultdict(lambda: defaultdict(int))
        for seg in data.segments:
            project = seg.project or NO_PROJECT_LABEL
            task = seg.task or NO_TASK_LABEL
            by_project[project][task] += seg.duration_sec

        header, lines = self._list_report_header("TASK", data)

        # Project rows with nested task rows
        for project in sorted(by_project):
            tasks = by_project[project]
            project_total = sum(tasks.values())
            duration = format_duration_compact(project_total)
            pct = format_percentage(project_total, data.total_duration)
            lines.append(f"{project:<22} {duration:>8}  {pct}")

            for task in sorted(tasks):
                duration = format_duration_compact(tasks[task])
                pct = format_percentage(tasks[task], data.total_duration)
                lines.append(f"  {task:<20} {duration:>8}  {pct}")

        lines.extend(self._list_report_footer(len(header), 22, data.total_duration))
        return '\n'.join(lines)

    @staticmethod
    def _temporal_sort_key(dim: str, value: str) -> int:
        """Sort key for temporal dimension values."""
        match dim:
            case "day":
                return DAY_NAMES_SHORT.index(value) if value in DAY_NAMES_SHORT else 99
            case "week":
                # "W01" -> 1
                return int(value[1:]) if value.startswith("W") else 99
            case "month":
                return MONTH_NAMES_SHORT.index(value) if value in MONTH_NAMES_SHORT else 99
            case "year":
                return int(value)
            case _:
                return 0

    def _render_2d(self, data: AggregatedData) -> str:
        """Render 2D cross-tabulation table.

        Dimensions are always ordered categorical × temporal.
        Auto-transposes when temporal columns exceed threshold.
        """
        dims = data.dimensions
        # Identify which is categorical, which is temporal
        cat_dim_idx = next(i for i, d in enumerate(dims) if d in CATEGORICAL_DIMS)
        cat_dim = dims[cat_dim_idx]
        temp_dim = dims[1 - cat_dim_idx]

        # Build cross-tab: {cat_val: {temp_val: seconds}}
        crosstab = defaultdict(lambda: defaultdict(int))
        temp_totals = defaultdict(int)
        for seg in data.segments:
            cat_val = get_dimension_value(seg, cat_dim)
            temp_val = get_dimension_value(seg, temp_dim)
            crosstab[cat_val][temp_val] += seg.duration_sec
            temp_totals[temp_val] += seg.duration_sec

        # Sort temporal values chronologically
        sorted_temp = sorted(temp_totals, key=lambda v: self._temporal_sort_key(temp_dim, v))

        # Sort categorical values: task alphabetically, others by total descending
        cat_totals = {cat: sum(vals.values()) for cat, vals in crosstab.items()}
        if cat_dim == "task":
            sorted_cat = sorted(cat_totals)
        else:
            sorted_cat = sorted(cat_totals, key=lambda c: cat_totals[c], reverse=True)

        # Auto-transpose: if too many temporal values, swap axes
        if len(sorted_temp) > CROSSTAB_TRANSPOSE_THRESHOLD:
            row_labels, col_labels = sorted_temp, sorted_cat
            row_dim, col_dim = temp_dim, cat_dim
            row_totals, col_totals = temp_totals, cat_totals

            def cell(row, col):
                return crosstab[col][row]
        else:
            row_labels, col_labels = sorted_cat, sorted_temp
            row_dim, col_dim = cat_dim, temp_dim
            row_totals, col_totals = cat_totals, temp_totals

            def cell(row, col):
                return crosstab[row][col]

        # Layout
        min_cw = max((len(c) for c in col_labels), default=0) + 2
        cw = max(CROSSTAB_COL_WIDTH, min_cw)
        label_width = max(len(r) for r in row_labels) + 2
        label_width = max(label_width, 12)
        table_width = label_width + (len(col_labels) + 1) * cw

        # Header
        lines = []
        title = f"{row_dim.upper()} × {col_dim.upper()}"
        if data.period_range:
            period_str = format_period_range(*data.period_range)
            title += f" ({period_str})"
        lines.append(title)
        lines.append(draw_header_separator(table_width))
        lines.append("")

        # Column headers
        header_line = " " * label_width
        for col in col_labels:
            header_line += f"{col:>{cw}}"
        header_line += f"{'Total':>{cw}}"
        lines.append(header_line)
        lines.append(draw_separator(table_width))

        # Data rows
        for row in row_labels:
            line = f"{row:<{label_width}}"
            for col in col_labels:
                val = cell(row, col)
                if val == 0:
                    line += f"{'·':>{cw}}"
                else:
                    line += f"{format_duration_compact(val):>{cw}}"
            line += f"{format_duration_compact(row_totals[row]):>{cw}}"
            lines.append(line)

        # Total row
        lines.append(draw_separator(table_width))
        total_line = f"{'Total':<{label_width}}"
        for col in col_labels:
            total_line += f"{format_duration_compact(col_totals[col]):>{cw}}"
        total_line += f"{format_duration_compact(data.total_duration):>{cw}}"
        lines.append(total_line)

        lines.append("")
        lines.append(draw_header_separator(table_width))
        lines.append("")

        return '\n'.join(lines)

    def _render_daily_calendar(self, data: AggregatedData, spec: CommandSpec) -> str:
        """Render daily calendar (grid/compact/sparse)"""
        if spec.sparse:
            return self._render_daily_sparse(data)
        elif spec.compact:
            return self._render_daily_compact(data)
        else:
            return self._render_daily_grid(data)

    @staticmethod
    def _group_segments_by_week(segments: list[Segment]) -> dict:
        """Group segments into {(iso_year, iso_week): {weekday: [segments]}}"""
        by_week = defaultdict(lambda: defaultdict(list))
        for seg in segments:
            dt = datetime.fromtimestamp(seg.start_epoch)
            iso = dt.isocalendar()
            by_week[(iso.year, iso.week)][dt.weekday()].append(seg)
        return by_week

    @staticmethod
    def _flatten_week_segments(week_segs_by_day: dict) -> list[Segment]:
        """Collect all segments for a week into a flat list."""
        return [seg for day_segs in week_segs_by_day.values() for seg in day_segs]

    @staticmethod
    def _week_start_date(segments: list[Segment]) -> datetime:
        """Monday of the week containing the earliest segment."""
        first_seg = min(segments, key=lambda s: s.start_epoch)
        first_dt = datetime.fromtimestamp(first_seg.start_epoch)
        return first_dt - timedelta(days=first_dt.weekday())

    def _render_week_footer(self, lines: list[str], week_segs_by_day: dict, col_width: int, total_width: int) -> None:
        """Render daily totals, week total, and closing separator."""
        totals_line = "Daily Total:    "
        week_total = 0
        for day_idx in range(7):
            day_total = sum(seg.duration_sec for seg in week_segs_by_day.get(day_idx, []))
            week_total += day_total
            if day_total > 0:
                total_str = format_duration(day_total)
                totals_line += f"{total_str:<{col_width}} "
            else:
                totals_line += f"{'-':<{col_width}} "

        lines.append(totals_line.rstrip())
        lines.append(draw_separator(total_width))
        lines.append(f"Week Total: {format_duration(week_total)}")
        lines.append(draw_header_separator(total_width))
        lines.append("")

    def _render_daily_sparse(self, data: AggregatedData) -> str:
        """Sparse format with fixed-height boxes and gaps"""
        lines = []
        by_week = self._group_segments_by_week(data.segments)
        sorted_weeks = sorted(by_week.keys())
        if not sorted_weeks:
            return "No time segments to display\n"

        for week_year, week_num in sorted_weeks:
            week_segs_by_day = by_week[(week_year, week_num)]
            all_week_segs = self._flatten_week_segments(week_segs_by_day)
            if not all_week_segs:
                continue

            week_start = self._week_start_date(all_week_segs)
            placements = self._place_boxes_sparse(week_segs_by_day)
            week_lines = self._render_week_sparse(
                placements, week_segs_by_day,
                week_start, week_num, week_year
            )
            lines.extend(week_lines)

        return '\n'.join(lines)

    def _render_daily_grid(self, data: AggregatedData) -> str:
        """Grid format with box rendering"""
        lines = []
        by_week = self._group_segments_by_week(data.segments)
        sorted_weeks = sorted(by_week.keys())
        if not sorted_weeks:
            return "No time segments to display\n"

        for week_year, week_num in sorted_weeks:
            week_segs_by_day = by_week[(week_year, week_num)]
            all_week_segs = self._flatten_week_segments(week_segs_by_day)
            if not all_week_segs:
                continue

            min_hour = min(datetime.fromtimestamp(seg.start_epoch).hour for seg in all_week_segs)
            max_hour = max(datetime.fromtimestamp(seg.end_epoch).hour for seg in all_week_segs) + 1

            week_start = self._week_start_date(all_week_segs)
            placements = self._place_boxes_in_grid(week_segs_by_day, min_hour)
            week_lines = self._render_week_grid(
                placements, week_segs_by_day, min_hour, max_hour,
                week_start, week_num, week_year
            )
            lines.extend(week_lines)

        return '\n'.join(lines)

    @staticmethod
    def _find_adjacent_column(column_last_seg: list, seg: Segment) -> int | None:
        """Column whose last segment is adjacent to seg, if any."""
        for col_idx, last_seg in enumerate(column_last_seg):
            if last_seg and segments_adjacent(last_seg, seg):
                return col_idx
        return None

    def _place_boxes_in_grid(self, week_segs_by_day: dict, min_hour: int) -> list[BoxPlacement]:
        """Place segments into grid positions using greedy column assignment"""
        placements = []

        for day_idx in range(7):
            day_segs = week_segs_by_day.get(day_idx, [])
            if not day_segs:
                continue

            # Sort by start time
            sorted_segs = sorted(day_segs, key=lambda s: s.start_epoch)

            # Track when each column becomes free (row index) and last segment in each column
            column_free_at = [0, 0, 0]  # Support up to 3 columns
            column_last_seg = [None, None, None]  # Last segment placed in each column

            for seg in sorted_segs:
                start_dt = datetime.fromtimestamp(seg.start_epoch)
                end_dt = datetime.fromtimestamp(seg.end_epoch)

                # Calculate row positions (15-min slots = 4 per hour)
                start_row = (start_dt.hour - min_hour) * 4 + start_dt.minute // 15
                end_row = (end_dt.hour - min_hour) * 4 + (end_dt.minute + 14) // 15

                # Ensure minimum box height of 3 rows (top border + content + bottom border)
                if end_row - start_row < 3:
                    end_row = start_row + 3

                # Force adjacent segments into the same column
                adjacent_column = self._find_adjacent_column(column_last_seg, seg)

                # Find available column
                column = None
                if adjacent_column is not None:
                    # Force adjacent segments into same column
                    column = adjacent_column
                    column_free_at[column] = end_row
                else:
                    # Normal greedy column assignment
                    for col_idx in range(3):
                        if column_free_at[col_idx] <= start_row:
                            column = col_idx
                            column_free_at[col_idx] = end_row
                            break

                if column is None:
                    # All columns full - skip
                    continue

                # Update last segment in column
                column_last_seg[column] = seg

                placements.append(BoxPlacement(
                    segment=seg,
                    day_idx=day_idx,
                    start_row=start_row,
                    end_row=end_row,
                    column=column
                ))

        return placements

    def _place_boxes_sparse(self, week_segs_by_day: dict) -> list[BoxPlacement]:
        """
        Place segments for sparse format (fixed-height boxes with gaps).
        Returns list of BoxPlacement objects with vertical stack positions.
        """
        placements = []

        for day_idx in range(7):
            day_segs = week_segs_by_day.get(day_idx, [])
            if not day_segs:
                continue

            # Sort by start time (chronological order)
            sorted_segs = sorted(day_segs, key=lambda s: s.start_epoch)

            # Track vertical position and column usage
            current_row = 0
            column_free_at = [0, 0, 0]  # Support up to 3 columns for overlaps
            column_last_seg = [None, None, None]

            for seg in sorted_segs:
                # Calculate fixed box dimensions
                start_row = current_row
                end_row = start_row + SPARSE_BOX_HEIGHT

                # Force adjacent segments into the same column
                adjacent_column = self._find_adjacent_column(column_last_seg, seg)

                # Find available column
                column = None
                overlaps_with_any = False
                if adjacent_column is not None:
                    # Force adjacent segments into same column
                    column = adjacent_column
                    column_free_at[column] = end_row
                else:
                    # Check for overlapping segments
                    for col_idx in range(3):
                        if column_free_at[col_idx] > start_row:
                            overlaps_with_any = True
                            break

                    if overlaps_with_any:
                        # Find first available column
                        for col_idx in range(3):
                            if column_free_at[col_idx] <= start_row:
                                column = col_idx
                                column_free_at[col_idx] = end_row
                                break
                    else:
                        # No overlap - use column 0
                        column = 0
                        column_free_at[0] = end_row

                if column is None:
                    # All columns full - skip
                    continue

                # Update last segment in column
                column_last_seg[column] = seg

                placements.append(BoxPlacement(
                    segment=seg,
                    day_idx=day_idx,
                    start_row=start_row,
                    end_row=end_row,
                    column=column
                ))

                # Move to next vertical position (after gap)
                if not overlaps_with_any:
                    current_row = end_row + SPARSE_GAP_HEIGHT

        return placements

    def _render_week_header(self, title_prefix: str, week_start: datetime, week_num: int, week_year: int, col_width: int, total_width: int, indent: str) -> list[str]:
        """Title and day column headers shared by grid and sparse formats."""
        week_end = week_start + timedelta(days=6)
        start_month = MONTH_NAMES_SHORT[week_start.month - 1]
        end_month = MONTH_NAMES_SHORT[week_end.month - 1]
        title = (f"{title_prefix}: {start_month} {week_start.day} - "
                 f"{end_month} {week_end.day} (Week {week_num}, {week_year})")

        lines = [title, draw_header_separator(total_width), ""]

        header_line = indent
        for day_idx in range(7):
            day_dt = week_start + timedelta(days=day_idx)
            date_str = f"{DAY_NAMES_FULL[day_idx]} ({day_dt.day})"
            header_line += f"{date_str:^{col_width}} "
        lines.append(header_line)
        lines.append(draw_separator(total_width))
        return lines

    def _render_box_rows(self, placements: list[BoxPlacement], total_rows: int, col_width: int, row_prefix) -> list[str]:
        """Render box grid rows; row_prefix(row_idx) supplies the left margin."""
        # Pre-index placements by day for efficient lookup
        placements_by_day = defaultdict(list)
        for p in placements:
            placements_by_day[p.day_idx].append(p)

        lines = []
        for row_idx in range(total_rows):
            row_line = row_prefix(row_idx)
            for day_idx in range(7):
                row_line += self._render_cell_with_boxes(
                    placements_by_day[day_idx], row_idx, col_width
                ) + " "
            lines.append(row_line.rstrip())
        return lines

    def _render_week_grid(self, placements, week_segs_by_day, min_hour, max_hour, week_start, week_num, week_year):
        """Render a week grid with boxes"""
        col_width = GRID_DAY_COL_WIDTH
        rows_per_hour = 4
        total_rows = (max_hour - min_hour) * rows_per_hour
        total_width = 6 + (col_width + 1) * 7

        lines = self._render_week_header(
            "DAILY CALENDAR", week_start, week_num, week_year,
            col_width, total_width, indent="      "
        )

        def time_label(row_idx: int) -> str:
            if row_idx % rows_per_hour == 0:
                return f"{min_hour + row_idx // rows_per_hour:02d}:00 "
            return "      "

        lines.extend(self._render_box_rows(placements, total_rows, col_width, time_label))

        lines.append(draw_separator(total_width))
        self._render_week_footer(lines, week_segs_by_day, col_width, total_width)
        return lines

    def _render_week_sparse(self, placements, week_segs_by_day, week_start, week_num, week_year):
        """Render a week in sparse format (no time labels, stacked boxes)"""
        col_width = GRID_DAY_COL_WIDTH
        total_rows = max((p.end_row for p in placements), default=0)
        total_width = (col_width + 1) * 7

        lines = self._render_week_header(
            "DAILY CALENDAR (SPARSE)", week_start, week_num, week_year,
            col_width, total_width, indent=""
        )

        lines.extend(self._render_box_rows(placements, total_rows, col_width, lambda _: ""))

        lines.append(draw_separator(total_width))
        self._render_week_footer(lines, week_segs_by_day, col_width, total_width)
        return lines

    def _render_cell_with_boxes(self, placements: list[BoxPlacement], row_idx: int, col_width: int) -> str:
        """Render a cell that may contain multiple boxes. Placements are pre-filtered for this day."""
        active_boxes = [
            p for p in placements
            if p.start_row <= row_idx < p.end_row
        ]

        # Boxes starting at current or next row (for adjacency detection)
        boxes_starting_next = [
            p for p in placements
            if p.start_row == row_idx or p.start_row == row_idx + 1
        ]

        if not active_boxes and not boxes_starting_next:
            return " " * col_width

        # Group boxes by column for adjacency detection
        boxes_by_column = {}
        for box in active_boxes:
            boxes_by_column.setdefault(box.column, {'active': [], 'starting_next': None})
            boxes_by_column[box.column]['active'].append(box)

        for box in boxes_starting_next:
            boxes_by_column.setdefault(box.column, {'active': [], 'starting_next': None})
            boxes_by_column[box.column]['starting_next'] = box

        # Sort columns
        sorted_columns = sorted(boxes_by_column.keys())
        num_columns = len([c for c in sorted_columns if boxes_by_column[c]['active']])

        # Calculate sub-column widths
        sub_width = (col_width - num_columns + 1) // num_columns if num_columns > 0 else col_width

        # Track boxes that should be skipped (starting boxes after connecting border)
        skip_boxes = set()

        # Render
        parts = []
        for col_idx in sorted_columns:
            col_data = boxes_by_column[col_idx]
            active_in_col = col_data['active']
            starting_next = col_data['starting_next']

            # Check for connecting border: one box ending, one starting or overlapping, adjacent epochs
            has_connecting_border = False

            # Find box ending at this row (last content row)
            ending_box = next((b for b in active_in_col if b.end_row - 1 == row_idx), None)

            if ending_box:
                # First check boxes that are starting next
                if starting_next:
                    is_adjacent_row = (starting_next.start_row == row_idx or
                                      starting_next.start_row == row_idx + 1)
                    if segments_adjacent(ending_box.segment, starting_next.segment) and is_adjacent_row:
                        has_connecting_border = True
                        skip_boxes.add(id(starting_next))

                # Also check other active boxes (for case where both start in same 15-min slot)
                if not has_connecting_border:
                    for box in active_in_col:
                        if box != ending_box:
                            # Check if this box starts around where ending_box ends
                            is_overlapping_adjacent = (box.start_row <= row_idx + 1)
                            if segments_adjacent(ending_box.segment, box.segment) and is_overlapping_adjacent:
                                has_connecting_border = True
                                break

            # Render boxes in this column
            if has_connecting_border:
                # Render connecting border instead of separate top/bottom borders
                part = f"├{'─' * (sub_width - 2)}┤"
                parts.append(part)
            else:
                # Check if multiple boxes start at the same row and are adjacent
                # In this case, only render the one that ends first, skip the others
                if len(active_in_col) > 1 and any(b.start_row == row_idx for b in active_in_col):
                    # Find boxes starting at this row
                    starting_here = [b for b in active_in_col if b.start_row == row_idx]
                    # Check if any pair is adjacent
                    boxes_to_skip_here = set()
                    for i, box1 in enumerate(starting_here):
                        for box2 in starting_here[i+1:]:
                            if segments_adjacent(box1.segment, box2.segment):
                                # Skip the longer box (the one that starts second chronologically)
                                if box1.segment.end_epoch < box2.segment.start_epoch:
                                    boxes_to_skip_here.add(id(box2))
                                else:
                                    boxes_to_skip_here.add(id(box1))
                    skip_boxes.update(boxes_to_skip_here)

                # Normal rendering
                for box in active_in_col:
                    # Skip boxes only at their start_row when a connecting border is rendered
                    if id(box) in skip_boxes and box.start_row == row_idx:
                        continue

                    # Check if this box has an adjacent previous (skip top border)
                    has_adj_prev = self._has_adjacent_prev(placements, box)
                    skip_top = has_adj_prev and box.start_row <= row_idx

                    has_adj_next = self._has_adjacent_next(placements, box)

                    part = self._render_box_row(box, row_idx, sub_width, skip_top_border=skip_top, has_adjacent_next=has_adj_next)
                    parts.append(part)

        result = "".join(parts)
        return result.ljust(col_width)

    def _has_adjacent_prev(self, placements: list[BoxPlacement], box: BoxPlacement) -> bool:
        """Check if a box has an adjacent previous segment in the same column.
        Placements must be pre-filtered for the same day."""
        for p in placements:
            if p.column == box.column and segments_adjacent(p.segment, box.segment):
                if p.end_row == box.start_row:
                    return True
                if p.start_row == box.start_row and p.end_row < box.end_row:
                    return True
        return False

    def _has_adjacent_next(self, placements: list[BoxPlacement], box: BoxPlacement) -> bool:
        """Check if a box has an adjacent next segment in the same column.
        Placements must be pre-filtered for the same day."""
        for p in placements:
            if p.column == box.column and p != box:
                # Handles case where both start in same 15-min slot
                is_adjacent_row = abs(p.start_row - box.end_row) <= 2
                if segments_adjacent(box.segment, p.segment) and is_adjacent_row:
                    return True
        return False

    def _render_box_row(self, box: BoxPlacement, row_idx: int, width: int, skip_top_border: bool = False, has_adjacent_next: bool = False) -> str:
        """Render one row of a box"""
        relative_row = row_idx - box.start_row
        box_height = box.end_row - box.start_row

        if relative_row == 0:
            if skip_top_border or (box_height == 2 and has_adjacent_next):
                content = self._get_box_content_line(box.segment, relative_row, box_height, width - 2)
                return f"│{content}│"
            else:
                return f"┌{'─' * (width - 2)}┐"

        if relative_row == box_height - 1:
            return f"└{'─' * (width - 2)}┘"

        content = self._get_box_content_line(box.segment, relative_row - 1, box_height, width - 2)
        return f"│{content}│"

    def _calculate_layout_category(self, box_height: int, content_width: int) -> tuple[str, str]:
        """
        Calculate layout category for adaptive content display.
        Returns: (width_category, height_category)
        """
        if content_width >= 14:
            width_cat = 'wide'
        elif content_width >= 7:
            width_cat = 'medium'
        else:
            width_cat = 'narrow'

        if box_height <= 2:
            height_cat = 'tiny'
        elif box_height <= 4:
            height_cat = 'short'
        elif box_height <= 6:
            height_cat = 'medium'
        elif box_height <= 8:
            height_cat = 'tall'
        else:
            height_cat = 'very_tall'

        return (width_cat, height_cat)

    def _format_time_abbreviated(self, start_dt: datetime, end_dt: datetime, width: int) -> str:
        """Format time range in abbreviated form based on available width"""
        if width >= 13:
            # Full format: "08:30-11:00"
            return f"{start_dt:%H:%M}-{end_dt:%H:%M}"
        elif width >= 7:
            # Medium format: "08-11" (hour only)
            return f"{start_dt:%H}-{end_dt:%H}"
        elif width >= 5:
            # Compact: "8-11"
            return f"{start_dt.hour}-{end_dt.hour}"
        else:
            # Start only: "08"
            return f"{start_dt:%H}"

    def _truncate_smart(self, text: str, max_width: int, indicator: str = "..") -> str:
        """Smart truncation with ellipsis"""
        if len(text) <= max_width:
            return text
        if max_width <= len(indicator):
            return text[:max_width]
        return text[:max_width - len(indicator)] + indicator

    def _get_box_content_line(self, seg: Segment, content_row: int, box_height: int, content_width: int) -> str:
        """Get content for a specific (0-based) line inside the box."""
        width_cat, height_cat = self._calculate_layout_category(box_height, content_width)
        content_rows = box_height if box_height <= 2 else box_height - 2

        content_lines = self._build_content_lines(seg, content_width, width_cat, height_cat, content_rows)

        if 0 <= content_row < len(content_lines):
            return content_lines[content_row].ljust(content_width)
        return " " * content_width

    def _build_content_lines(
        self, seg: Segment,
        width: int, width_cat: str, height_cat: str, content_rows: int,
    ) -> list[str]:
        """
        Build list of content lines based on layout category and priority.
        content_rows: Number of content rows available (excluding borders)
        """
        project = seg.project or "?"
        task = seg.task or ""
        start_dt = datetime.fromtimestamp(seg.start_epoch)
        end_dt = datetime.fromtimestamp(seg.end_epoch)
        duration = format_duration(seg.duration_sec)

        lines = []

        # PRIORITY 1: Project (always show)
        if height_cat == 'tiny' and width >= 10:
            # Combine project + duration on one line for tiny boxes
            proj_abbrev = project[:8] if len(project) > 8 else project
            lines.append(self._truncate_smart(f"{proj_abbrev} {duration}", width))
        else:
            # Normal: project on its own line
            lines.append(self._truncate_smart(project, width, ".."))

        # PRIORITY 2: Task (own line below project)
        if task:
            lines.append(self._truncate_smart(task, width, ".."))

        # PRIORITY 3-5: Time, Duration, Description
        # Remaining rows after project/task lines
        remaining_rows = content_rows - len(lines)

        if width_cat == 'narrow':
            lines.extend(self._build_narrow_content(
                seg.description, start_dt, end_dt, duration,
                width, height_cat, remaining_rows
            ))
        else:
            # Wide and medium differ only in the truncation indicator
            indicator = "..." if width_cat == 'wide' else ".."
            lines.extend(self._build_time_duration_content(
                seg.description, start_dt, end_dt, duration,
                width, height_cat, remaining_rows, indicator
            ))

        return lines

    def _build_time_duration_content(
        self, description: str, start_dt: datetime, end_dt: datetime,
        duration: str, width: int, height_cat: str, remaining_rows: int,
        desc_indicator: str,
    ) -> list[str]:
        """Build time/duration/description lines for WIDE (14+) and MEDIUM (7-13) widths"""
        if height_cat == 'tiny':
            # Project + duration already combined in first line
            return []

        # Row 2: Time
        lines = [self._format_time_abbreviated(start_dt, end_dt, width)]

        if height_cat == 'short':
            # Row 3: Duration
            if remaining_rows >= 3:
                lines.append(duration)
        else:  # medium, tall, very_tall
            # Row 3: Duration
            # Row 4: Description (truncated)
            lines.append(duration)
            if remaining_rows >= 4 and description:
                lines.append(self._truncate_smart(description, width, desc_indicator))

        return lines

    def _build_narrow_content(
        self, description: str, start_dt: datetime, end_dt: datetime,
        duration: str, width: int, height_cat: str, remaining_rows: int,
    ) -> list[str]:
        """Build content for NARROW width (3-6 chars)"""
        if height_cat == 'tiny':
            # Only project (abbrev) in first line
            return []

        # Row 2: Duration
        lines = [duration]

        if height_cat != 'short':  # medium, tall, very_tall
            # Row 3: Time (hour only)
            # Row 4: Description indicator icon
            if remaining_rows >= 3:
                lines.append(self._format_time_abbreviated(start_dt, end_dt, width))
            if remaining_rows >= 4 and description:
                lines.append('"')

        return lines

    def _render_daily_compact(self, data: AggregatedData) -> str:
        """Vertical timeline format"""
        lines = []

        # Group segments by day
        by_day = defaultdict(list)
        for seg in data.segments:
            day_key = datetime.fromtimestamp(seg.start_epoch).date()
            by_day[day_key].append(seg)

        # Sort days chronologically
        sorted_days = sorted(by_day.keys())

        if not sorted_days:
            return "No time segments to display\n"

        # Build header
        if len(sorted_days) == 1:
            day_dt = datetime.combine(sorted_days[0], datetime.min.time())
            header = f"DAILY CALENDAR: {format_day(day_dt.weekday(), full=True)}, {MONTH_NAMES_SHORT[day_dt.month - 1]} {day_dt.day} ({day_dt.year})"
        else:
            first_dt = datetime.combine(sorted_days[0], datetime.min.time())
            last_dt = datetime.combine(sorted_days[-1], datetime.min.time())

            # Check if within same week
            first_iso = first_dt.isocalendar()
            last_iso = last_dt.isocalendar()

            if first_iso.year == last_iso.year and first_iso.week == last_iso.week:
                header = f"DAILY CALENDAR: {MONTH_NAMES_SHORT[first_dt.month - 1]} {first_dt.day} - {MONTH_NAMES_SHORT[last_dt.month - 1]} {last_dt.day} (Week {first_iso.week}, {first_dt.year})"
            else:
                header = f"DAILY CALENDAR: {MONTH_NAMES_SHORT[first_dt.month - 1]} {first_dt.day} ({first_dt.year}) - {MONTH_NAMES_SHORT[last_dt.month - 1]} {last_dt.day} ({last_dt.year})"

        lines.append(header)
        lines.append(draw_header_separator(len(header)))
        lines.append("")

        # Render each day
        current_week = None
        week_duration = 0
        for day_date in sorted_days:
            day_segs = sorted(by_day[day_date], key=lambda s: s.start_epoch)
            day_dt = datetime.combine(day_date, datetime.min.time())
            iso_week = day_dt.isocalendar()[:2]

            # Week separator
            if current_week is not None and iso_week != current_week:
                week_total_str = f"Week Total: {format_duration(week_duration)}"
                lines.append(f"{week_total_str:>{COMPACT_FORMAT_WIDTH}}")
                lines.append("")
                lines.append("")
                week_duration = 0
            current_week = iso_week

            # Day total
            day_total = sum(seg.duration_sec for seg in day_segs)
            week_duration += day_total
            day_header = f"{format_day(day_dt.weekday(), full=True)}, {MONTH_NAMES_SHORT[day_dt.month - 1]} {day_dt.day}"
            day_total_str = format_duration(day_total)

            # Right-align total
            padding = COMPACT_FORMAT_WIDTH - len(day_header) - len(day_total_str)
            lines.append(f"{day_header}{' ' * padding}{day_total_str}")
            lines.append(draw_separator(COMPACT_FORMAT_WIDTH))

            if not day_segs:
                lines.append("(no time tracked)")
            else:
                # Detect overlaps
                overlaps = self._detect_day_overlaps(day_segs)

                for i, seg in enumerate(day_segs):
                    # Format time
                    start_dt = datetime.fromtimestamp(seg.start_epoch)
                    end_dt = datetime.fromtimestamp(seg.end_epoch)
                    time_start = start_dt.strftime("%H:%M")
                    time_range = f"{time_start}-{end_dt.strftime('%H:%M')}"
                    duration = format_duration(seg.duration_sec)

                    # Project name
                    label = seg.project or NO_PROJECT_LABEL

                    # Check if this segment overlaps with next
                    is_overlap = i in overlaps
                    is_last_in_overlap = is_overlap and (i + 1) not in overlaps

                    if is_overlap:
                        prefix = "└─" if is_last_in_overlap else "├─"
                        overlap_warn = "  ⚠ overlap"
                    else:
                        prefix = "  "
                        overlap_warn = ""

                    # Format primary line with project
                    line = f"{time_start}  {prefix}{label:<22}  {time_range}  {duration}{overlap_warn}"
                    lines.append(line)

                    # Add task/note line (indented): task: "note"
                    desc = self._truncate_description(seg.description, max_len=50)
                    detail = seg.task or ""
                    if desc:
                        detail = f"{detail}: \"{desc}\"" if detail else f"\"{desc}\""
                    if detail:
                        indent_prefix = "       " + ("│ " if is_overlap and not is_last_in_overlap else "  ")
                        lines.append(f"{indent_prefix}{detail}")

            lines.append("")

        # Last week total
        if week_duration > 0 and len(sorted_days) > 1:
            week_total_str = f"Week Total: {format_duration(week_duration)}"
            lines.append(f"{week_total_str:>{COMPACT_FORMAT_WIDTH}}")
            lines.append("")

        # Footer
        lines.append(draw_header_separator(COMPACT_FORMAT_WIDTH))
        if len(sorted_days) == 1:
            footer = f"Total: {format_duration(data.total_duration)}"
        else:
            footer = f"Period Total: {format_duration(data.total_duration)}"
        lines.append(footer)
        lines.append("")

        return '\n'.join(lines)

    def _detect_day_overlaps(self, segments: list[Segment]) -> set[int]:
        """Detect which segment indices overlap with their next segment"""
        overlaps = set()
        for i in range(len(segments) - 1):
            if segments[i].end_epoch > segments[i + 1].start_epoch:
                overlaps.add(i)
                overlaps.add(i + 1)
        return overlaps

    def _truncate_description(self, desc: str, max_len: int = 50) -> str:
        """Truncate description intelligently at word boundaries"""
        if not desc:
            return ""

        if len(desc) <= max_len:
            return desc

        # Truncate at word boundary
        truncated = desc[:max_len].rsplit(' ', 1)[0]
        return truncated + "..."


# ============================================================================
# SECTION 7: CLI ORCHESTRATION
# ============================================================================

def execute_pipeline(spec: CommandSpec) -> str:
    """Execute complete reporting pipeline"""

    # Stage 1: Load data
    blocks = load_zeit_data()

    # Stage 2-3: Extract and preprocess
    raw_segments = extract_segments(blocks)
    segments = preprocess_segments(raw_segments)

    # Stage 4: Period filtering
    if spec.period_expr:
        segments = apply_period_filter(segments, spec.period_expr)

    # Check if we have any data
    if not segments:
        return "No time segments found for the specified period.\n"

    # Stage 5: Aggregation
    data = aggregate_by_dimensions(
        segments,
        [d.name for d in spec.dimensions],
    )

    # Stage 6: Rendering
    renderer = Renderer()
    output = renderer.render(data, spec)

    return output


def build_argument_parser() -> argparse.ArgumentParser:
    """Build argument parser"""
    parser = argparse.ArgumentParser(
        description="Zeit time tracking visualizer",
        epilog="Examples:\n"
               "  zeit export -f json | timereport project\n"
               "  zeit export -f json | timereport dailycal --period week\n",
        formatter_class=argparse.RawDescriptionHelpFormatter
    )

    parser.add_argument(
        'dimensions',
        nargs='*',
        help='Dimension to report on (project, task, day, week, month, year) '
             'or command (dailycal)'
    )

    parser.add_argument(
        '--period',
        help='Period filter (today, yesterday, week, lastweek, month, lastmonth, '
             'year, lastyear, Ndays, Nweeks, Nmonths, Nyears)'
    )

    parser.add_argument(
        '--compact',
        action='store_true',
        help='Use compact format for dailycal'
    )

    parser.add_argument(
        '--sparse',
        action='store_true',
        help='Use sparse format for dailycal (fixed-height boxes with gaps)'
    )

    return parser


# ============================================================================
# SECTION 8: MAIN ENTRY POINT
# ============================================================================

def main(argv: list[str] | None = None) -> int:
    """Main entry point"""
    parser = build_argument_parser()
    args = parser.parse_args(argv)

    try:
        # Build command specification
        spec = build_command_spec(args)

        # Execute pipeline
        output = execute_pipeline(spec)

        # Print to stdout
        print(output, end='')

        return 0

    except ValueError as e:
        print(f"Error: {e}", file=sys.stderr)
        return 1
    except RuntimeError as e:
        print(f"Error: {e}", file=sys.stderr)
        return 1
    except Exception as e:
        print(f"Unexpected error: {e}", file=sys.stderr)
        import traceback
        traceback.print_exc()
        return 2


if __name__ == "__main__":
    sys.exit(main())
