#!/usr/bin/env bash
#
# zet - zettlekasten utility
#
# Wrapper around note. Quickly create and find zettlekasten.

show_help() {
    cat <<'EOF'
zet - zettlekasten utility

USAGE
    zet <command> [args]

COMMANDS
    find [<query>]
                           fzf .md files under $NOTE_HOME/zet, open in vim,
                             auto open on a single match
    open <name>             open $NOTE_HOME/zet/<name>.md on vim.
                             Use to either open or create a new note.

    completion             print bash completion script to stdout
    help                   show this message


INSTALL COMPLETION
    bash:   zet completion > ~/.local/share/bash-completion/completions/zet
    eval:   eval "$(zet completion)"
EOF
}

main() {
    local root="${NOTE_HOME:-$HOME/notes}/zet"

    case "$1" in
    ""|help|-h|--help)
        show_help
        ;;

    find)
        shift
        [ "$#" -le 1 ] || { echo "unexpected args: $*" >&2; exit 1; }
        local query="$1"
        local fzf_args=(-e -1 -0)
        [ -n "$query" ] && fzf_args+=(-q "$query")
        local f
        f=$(rg --files --type md --glob '!_*' "$root" \
            | sed "s|^$root/||" | fzf "${fzf_args[@]}") \
            && [ -n "$f" ] && vim "$root/$f"
        ;;

    open)
        [ -n "$2" ] || { echo "usage: zet open <name>" >&2; exit 1; }
        local dst="$root/$2.md"
        mkdir -p "$(dirname "$dst")" || exit 1
        vim "$dst"
        ;;

    completion)
        cat <<'EOF'
_zet() {
    local cur="${COMP_WORDS[COMP_CWORD]}"
    local home="${NOTE_HOME:-$HOME/notes}"

    if [ "$COMP_CWORD" = 1 ]; then
        COMPREPLY=($(compgen -W "find open help completion" -- "$cur"))
        return
    fi
    case "${COMP_WORDS[1]}" in
        open)
            [ "$COMP_CWORD" = 2 ] || return
            local zet="$home/zet"
            local _ncg=
            shopt -q nocaseglob && _ncg=1
            shopt -s nocaseglob
            local f name rel entries=()
            for f in "$zet/$cur"*; do
                [ -e "$f" ] || continue
                name="${f##*/}"
                [[ "$name" == _* ]] && continue
                rel="${f#$zet/}"
                if [ -d "$f" ]; then
                    entries+=("$rel/")
                elif [[ "$name" == *.md ]]; then
                    entries+=("${rel%.md}")
                fi
            done
            [ -z "$_ncg" ] && shopt -u nocaseglob
            COMPREPLY=("${entries[@]}")
            [ "${#COMPREPLY[@]}" = 1 ] && [[ "${COMPREPLY[0]}" == */ ]] \
                && compopt -o nospace 2>/dev/null
            ;;
    esac
}
complete -F _zet zet
EOF
        ;;

    *)
        echo "unknown command: $1" >&2
        show_help
        exit 1
        ;;
    esac
}

main "$@"
